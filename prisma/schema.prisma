generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  color String
  tasks Task[]
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  categoryId  Int
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}
